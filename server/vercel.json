{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/crawl-trigger",
      "dest": "/api/crawl-trigger.js"
    },
    {
      "src": "/api/crawl-status",
      "dest": "/api/crawl-status.js"
    },
    {
      "src": "/api/matching-feed",
      "dest": "/api/matching-feed.js"
    },
    {
      "src": "/api/ai-analyze",
      "dest": "/api/ai-analyze.js"
    },
    {
      "src": "/api/privacy",
      "dest": "/api/privacy.js"
    },
    {
      "src": "/api/training-crawl",
      "dest": "/api/training-crawl.js"
    },
    {
      "src": "/api/training-generate",
      "dest": "/api/training-generate.js"
    }
  ],
  "crons": [
    {
      "path": "/api/crawl-trigger",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/crawl-trigger",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/training-crawl",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/training-crawl",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/training-crawl",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/training-crawl",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/training-crawl",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/training-crawl",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/training-crawl?mode=community",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/training-crawl?mode=community",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/training-generate",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/training-generate",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/training-generate",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/training-generate",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/training-generate",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/training-generate",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/training-generate",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/training-generate",
      "schedule": "0 22 * * *"
    }
  ]
}
